  clientId      String?  @map("client_id") @db.Uuid
  usageType     String   @map("usage_type")
  quantity      Decimal  @db.Decimal(12, 4)
  unit          String   @default("count")
  cost          Decimal? @db.Decimal(12, 6)
  currency      String   @default("USD")
  recordedAt    DateTime @default(now()) @map("recorded_at")
  referenceId   String?  @map("reference_id")
  referenceType String?  @map("reference_type")
  metadata      Json?    @default("{}")
  createdBy     String?  @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([companyId, usageType, recordedAt])
  @@index([companyId, clientId, usageType])
  @@index([companyId, referenceType, referenceId])
  @@map("usage_records")
}

// ============================================================
// 28. DOCUMENT RAG & CITATIONS
// ============================================================

model Document {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title       String
  fileName    String?  @map("file_name")
  fileType    String?  @map("file_type")
  fileSize    Int?     @map("file_size")
  source      String   @default("upload")
  category    String?
  lawType     String?  @map("law_type")
  lawNumber   String?  @map("law_number")
  article     String?  @map("article")
  year        Int?
  issuer      String?
  status      String   @default("PENDING")
  error       String?
  chunkCount  Int      @default(0) @map("chunk_count")
  metadata    Json?    @default("{}")
  uploadedBy  String?  @map("uploaded_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  chunks      DocumentChunk[]

  @@index([companyId, status])
  @@index([companyId, category])
  @@index([companyId, lawType])
  @@index([companyId, createdAt])
  @@map("documents")
}

model DocumentChunk {
  id          String    @id @default(uuid()) @db.Uuid
  documentId  String    @map("document_id") @db.Uuid
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  companyId   String    @map("company_id") @db.Uuid
  index       Int
  content     String    @db.Text
  tokens      Int       @default(0)
  embedding   Unsupported("vector(1536)")?
  metadata    Json?     @default("{}")
  lawType     String?   @map("law_type")
  article     String?   @map("article")
  hasISD      Boolean   @default(false) @map("has_isd")
  isd         Json?     @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")

  citations   Citation[]

  @@index([documentId, index])
  @@index([companyId])
  @@index([companyId, lawType])
  @@index([companyId, hasISD])
  @@index([companyId])
  @@map("document_chunks")
}

model Citation {
  id          String        @id @default(uuid()) @db.Uuid
  chunkId     String        @map("chunk_id") @db.Uuid
  chunk       DocumentChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  companyId   String        @map("company_id") @db.Uuid
  sessionId   String        @map("session_id")
  messageId   String?       @map("message_id")
  relevance   Float         @default(0.0)
  content     String        @db.Text
  lawType     String?       @map("law_type")
  article     String?       @map("article")
  metadata    Json?         @default("{}")
  createdAt   DateTime      @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([companyId, sessionId])
  @@index([chunkId])
  @@map("citations")
}

model AgentFeedback {
  id         String   @id @default(uuid()) @db.Uuid
  companyId  String   @map("company_id") @db.Uuid
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sessionId  String   @map("session_id")
  messageId  String?  @map("message_id")
  rating     Int
  category   String?
  comment    String?  @db.Text
  metadata   Json?    @default("{}")
  createdBy  String?  @map("created_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([companyId, createdAt])
  @@index([companyId, rating])
  @@map("agent_feedback")
}

// ============================================================
// 29. CHAT AGÉNTICO CON LANGGRAPH + MEMORIA
// ============================================================

model ChatSession {
  id              String        @id @default(uuid()) @db.Uuid
  companyId       String        @map("company_id") @db.Uuid
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId          String        @map("user_id") @db.Uuid
  clientId        String?       @map("client_id") @db.Uuid
  title           String?
  primaryAgent    String?       @map("primary_agent")
  status          String        @default("ACTIVE")
  totalTokens     Int           @default(0) @map("total_tokens")
  totalCostUsd    Decimal       @default(0) @map("total_cost_usd") @db.Decimal(10, 6)
  initialContext  Json?         @map("initial_context")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  lastMessageAt   DateTime?     @map("last_message_at")

  messages        ChatMessage[]
  feedbacks       AgentFeedback[]

  @@index([companyId, userId, status])
  @@index([companyId, clientId])
  @@index([createdAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id               String        @id @default(uuid()) @db.Uuid
  companyId        String        @map("company_id") @db.Uuid
  sessionId        String        @map("session_id") @db.Uuid
  session          ChatSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role             String
  content          String        @db.Text
  reasoning        String?       @db.Text
  agentUsed        String?       @map("agent_used")
  modelUsed        String?       @map("model_used")
  toolsExecuted    Json?         @map("tools_executed")
  promptTokens     Int           @default(0) @map("prompt_tokens")
  completionTokens Int           @default(0) @map("completion_tokens")
  totalTokens      Int           @default(0) @map("total_tokens")
  costUsd          Decimal       @default(0) @map("cost_usd") @db.Decimal(10, 6)
  latencyMs        Int?          @map("latency_ms")
  firstTokenMs     Int?          @map("first_token_ms")
  lastTokenMs      Int?          @map("last_token_ms")
  citationIds      Json?         @default("[]") @map("citation_ids")
  metadata         Json?
  createdAt        DateTime      @default(now()) @map("created_at")

  toolLogs         ToolCallLog[]

  @@index([companyId, sessionId])
  @@index([companyId, role, createdAt])
  @@map("chat_messages")
}

model ToolCallLog {
  id               String        @id @default(uuid()) @db.Uuid
  companyId        String        @map("company_id") @db.Uuid
  messageId        String        @map("message_id") @db.Uuid
  message          ChatMessage   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  toolName         String        @map("tool_name")
  toolInput        Json          @map("tool_input")
  toolOutput       Json?         @map("tool_output")
  success          Boolean
  errorMessage     String?       @map("error_message")
  executionTimeMs  Int           @default(0) @map("execution_time_ms")
  sequenceNumber   Int           @default(0) @map("sequence_number")
  createdAt        DateTime      @default(now()) @map("created_at")

  @@index([companyId, messageId])
  @@index([companyId, toolName])
  @@map("tool_call_logs")
}
