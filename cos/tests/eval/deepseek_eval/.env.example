# Variables de entorno para COS Ecuador - Evaluación DeepSeek V4 Flash
# Copia este archivo a .env y completa con tus API keys reales.
# NUNCA commitees el archivo .env al repositorio.

# === DeepSeek (target primario) ===
# Obtén tu API key en https://platform.deepseek.com/api_keys
# Costo referencial: $0.14/M input + $0.28/M output
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === OpenAI (para comparación y como LLM-as-judge) ===
# Obtén tu API key en https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Anthropic (para comparación con Claude Haiku) ===
# Obtén tu API key en https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Configuración opcional ===
# Nivel de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
