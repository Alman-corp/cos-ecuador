{
  "name": "bios-platform",
  "version": "1.0.0",
  "description": "Business Intelligence OS — Platforma de Inteligencia Empresarial",
  "author": "BI OS Platform Team",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "dev:electron": "concurrently \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "next build",
    "build:standalone": "set NEXT_OUTPUT=standalone&& next build",
    "start": "next start -p 3456",
    "start:electron": "electron .",
    "package:win": "npm run build:standalone && electron-builder --win",
    "package:win-portable": "npm run build:standalone && electron-builder --win portable",
    "lint": "eslint",
    "electron:dev": "electron .",
    "beta": "next dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "build": {
    "appId": "com.bios.platform",
    "productName": "BI OS Platform",
    "electronVersion": "33.4.11",
    "directories": {
      "output": "dist-electron",
      "buildResources": "electron"
    },
    "files": [
      "electron/**/*",
      "next.config.ts",
      "package.json",
      ".next/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "server",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BI OS Platform",
      "installerIcon": "electron/icon.ico",
      "uninstallerIcon": "electron/icon.ico",
      "installerHeaderIcon": "electron/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${arch}.exe",
      "requestExecutionLevel": "user"
    },
    "asar": false,
    "asarUnpack": [
      "node_modules/next/**"
    ]
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.63.0",
    "@stripe/stripe-js": "^9.9.0",
    "@supabase/ssr": "^0.6.0",
    "@supabase/supabase-js": "^2.49.4",
    "@tanstack/react-query": "^5.62.0",
    "date-fns": "^4.1.0",
    "jose": "^6.2.3",
    "lightningcss": "^1.32.0",
    "lucide-react": "^0.487.0",
    "next": "16.2.9",
    "pino": "^9.14.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^2.15.0",
    "resend": "^6.17.1",
    "stripe": "^22.3.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.6",
    "concurrently": "^9.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "lightningcss-linux-x64-gnu": "^1.32.0",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.6",
    "wait-on": "^8.0.1",
    "xss": "^1.0.15"
  }
}
